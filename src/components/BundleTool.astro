---
// BundleTool component - PDF processing interface
---

<div id="bundle-tool-container" class="space-y-2">
  <form id="upload-form" class="space-y-2">
    <!-- Step 1: Basic Information -->
    <div class="bg-gradient-to-br from-slate-50 to-white rounded-xl shadow-sm border border-slate-200">
      <div class="px-3 py-2 bg-gradient-to-r from-slate-700 to-slate-800 rounded-t-xl">
        <h3 class="text-base font-bold text-white flex items-center">
          <span class="inline-flex items-center justify-center w-7 h-7 bg-pink-500 text-white rounded-full mr-2 text-sm font-bold shadow-lg">1</span>
          Basic Information
        </h3>
      </div>

      <div class="p-3 space-y-2">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <!-- Claim Number -->
          <div>
            <label for="config-claimNumber" class="block text-xs font-medium text-gray-600 mb-1">
              Claim Number
            </label>
            <input
              type="text"
              id="config-claimNumber"
              class="w-full px-2 py-1 text-sm border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
              placeholder="e.g., 2026-ABC-123 or HP-2026-000001"
            />
          </div>

          <!-- Bundle Title -->
          <div>
            <label for="config-bundleTitle" class="block text-xs font-medium text-gray-600 mb-1">
              Bundle Title
            </label>
            <input
              type="text"
              id="config-bundleTitle"
              placeholder="e.g., Bundle A: Statements of Case"
              class="w-full px-2 py-1 text-sm border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
            />
          </div>

          <!-- Project Name (Case Name) -->
          <div>
            <label for="config-projectName" class="block text-xs font-medium text-gray-600 mb-1">
              Case Name
            </label>
            <input
              type="text"
              id="config-projectName"
              class="w-full px-2 py-1 text-sm border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
              placeholder="e.g., Smith v. Jones"
            />
          </div>

          <!-- Confidential Checkbox -->
          <div class="flex items-center h-full pt-4">
            <label class="flex items-center space-x-2 cursor-pointer">
              <input
                type="checkbox"
                id="config-confidential"
                class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500"
              />
              <span class="text-sm font-medium text-gray-700">Mark as <span class="text-red-500">Confidential</span>?</span>
            </label>
          </div>
        </div>

        <!--
          Edit Existing Bundle Button
          <div class="pt-4 border-t border-gray-200">
            <p class="text-sm text-gray-600 mb-3">
              To edit an existing bundle:
            </p>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">
                Select Existing Bundle
              </label>
              <input
                type="file"
                id="bundle-input"
                accept="application/pdf"
                class="block w-full text-sm text-gray-500 file:mr-4 file:py-3 file:px-6 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-green-50 file:text-green-700 hover:file:bg-green-100 transition cursor-pointer"
              />
              <p class="mt-2 text-xs text-gray-500">
                Select a previously-created BunTool bundle to extract and edit its documents
              </p>
            </div>
        </div>
        -->
      </div>
    </div>

    <!-- Step 2: Select Documents -->
    <div class="bg-gradient-to-br from-slate-50 to-white rounded-xl shadow-sm border border-slate-200">
      <div class="px-3 py-2 bg-gradient-to-r from-slate-700 to-slate-800 rounded-t-xl">
        <h3 class="text-base font-bold text-white flex items-center">
          <span class="inline-flex items-center justify-center w-7 h-7 bg-pink-500 text-white rounded-full mr-2 text-sm font-bold shadow-lg">2</span>
          Select Documents
        </h3>
      </div>

      <div class="p-3 flex items-center gap-3">
        <label for="file-input" class="inline-flex items-center px-4 py-1.5 bg-pink-50 hover:bg-pink-100 text-pink-700 text-sm font-semibold rounded cursor-pointer transition">
          Add documents
        </label>
        <input type="file" id="file-input" multiple accept="application/pdf" class="sr-only" />
        <p id="file-input-hint" class="text-xs text-gray-400">Files stay on your device — nothing is uploaded.</p>
      </div>
    </div>

    <!-- Step 3: Review Table (initially hidden) -->
    <div id="file-table" class="bg-gradient-to-br from-slate-50 to-white rounded-xl shadow-sm border border-slate-200 hidden">
      <div class="px-3 py-2 bg-gradient-to-r from-slate-700 to-slate-800 rounded-t-xl flex items-center justify-between gap-3 flex-wrap">
        <div>
          <h3 class="text-base font-bold text-white flex items-center">
            <span class="inline-flex items-center justify-center w-7 h-7 bg-pink-500 text-white rounded-full mr-2 text-sm font-bold shadow-lg">3</span>
            Review Table
          </h3>
          <p class="mt-1 text-xs text-slate-200">Click titles/dates to edit</p>
        </div>
        <button id="reorder-toggle-btn" type="button"
          class="inline-flex items-center px-3 py-1.5 bg-slate-600 hover:bg-slate-500 text-white text-xs font-medium rounded-lg transition shrink-0"
          title="Switch between drag and button reordering"
          aria-pressed="false">
          Use buttons instead of drag
        </button>
      </div>

      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <colgroup>
            <col style="width: 40px;">
            <col style="width: 25%;">
            <col style="width: 50%;">
            <col style="width: 180px;">
            <col style="width: 60px;">
            <col style="width: 80px;">
          </colgroup>
          <thead class="bg-slate-100">
            <tr>
              <th class="px-2 py-2 text-left text-xs font-semibold text-slate-700 uppercase tracking-wider">
                <span class="sr-only">Drag</span>
              </th>
              <th class="px-3 py-2 text-left text-xs font-semibold text-slate-700 uppercase tracking-wider">Filename</th>
              <th class="px-4 py-2 text-left text-xs font-semibold text-slate-700 uppercase tracking-wider">Title</th>
              <th class="px-4 py-2 text-left text-xs font-semibold text-slate-700 uppercase tracking-wider">Date</th>
              <th class="px-4 py-2 text-left text-xs font-semibold text-slate-700 uppercase tracking-wider">Pages</th>
              <th class="px-4 py-2 text-left text-xs font-semibold text-slate-700 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody id="file-table-body" class="bg-white divide-y divide-gray-200">
            <!-- Rows will be added here by frontend.js -->
          </tbody>
        </table>
      </div>

      <!-- Table Controls -->
      <div class="px-4 py-2 border-t border-gray-200 flex justify-between items-center gap-2 flex-wrap">
        <button id="add-section-break-btn" type="button" class="inline-flex items-center px-3 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-lg transition">
          <svg class="w-3.5 h-3.5 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          Add Section Break
        </button>
        <button id="clear-all-rows-btn" type="button" class="inline-flex items-center px-3 py-1.5 bg-red-100 hover:bg-red-200 text-red-700 text-sm font-medium rounded-lg transition">
          <svg class="w-3.5 h-3.5 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
          Clear All
        </button>
      </div>
    </div>

    <!-- Step 4: Generate or Configure -->
    <div id="step-4-choice" class="bg-gradient-to-br from-slate-50 to-white rounded-xl shadow-sm border border-slate-200 hidden">
      <div class="px-3 py-2 bg-gradient-to-r from-slate-700 to-slate-800 rounded-t-xl">
        <h3 class="text-base font-bold text-white flex items-center">
          <span class="inline-flex items-center justify-center w-7 h-7 bg-pink-500 text-white rounded-full mr-2 text-sm font-bold shadow-lg">4</span>
          Create Bundle
        </h3>
      </div>

      <div class="p-3 flex flex-col sm:flex-row gap-2 justify-center">
        <button
          type="submit"
          class="inline-flex items-center justify-center px-8 py-3 bg-pink-500 hover:bg-pink-600 text-white text-base font-bold rounded-lg shadow-lg transition duration-150 ease-in-out focus:outline-none focus:ring-2 focus:ring-pink-500 focus:ring-offset-2 transform hover:scale-105"
        >
          <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Create Bundle
        </button>

        <button
          id="show-advanced-btn"
          type="button"
          class="inline-flex items-center justify-center px-8 py-3 bg-slate-700 hover:bg-slate-800 text-white text-base font-semibold rounded-lg shadow-lg transition duration-150 ease-in-out focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-offset-2"
        >
          <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          Advanced Settings
        </button>
      </div>
    </div>

    <!-- Advanced Settings (initially hidden) -->
    <div id="advanced-settings" class="bg-gradient-to-br from-slate-50 to-white rounded-xl shadow-sm border border-slate-200 hidden">
      <div class="px-3 py-2 bg-gradient-to-r from-slate-700 to-slate-800 rounded-t-xl">
        <h3 class="text-base font-bold text-white flex items-center">
          <svg class="w-5 h-5 mr-2 text-pink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          Advanced Settings
        </h3>
      </div>

      <div class="p-3 space-y-3">
        <!-- Index Options -->
        <div>
          <h4 class="text-xs font-semibold text-gray-700 mb-2">Index Options</h4>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
            <!-- Index Font -->
            <div>
              <label for="config-fontFace" class="block text-xs font-medium text-gray-600 mb-1">
                Index Font
              </label>
              <select
                id="config-fontFace"
                class="w-full px-2 py-1 text-sm border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
              >
                <option value="sansSerif">Sans Serif</option>
                <option value="serif">Modern Serif</option>
                <option value="monospaced">Monospaced</option>
                <option value="traditional">Traditional Serif</option>
              </select>
            </div>

            <!-- Date Format -->
            <div>
              <label for="config-dateStyle" class="block text-xs font-medium text-gray-600 mb-1">
                Date Format
              </label>
              <select
                id="config-dateStyle"
                class="w-full px-2 py-1 text-sm border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
              >
                <option value="YYYY-MM-DD">YYYY-MM-DD</option>
                <option value="DD-MM-YYYY">DD-MM-YYYY</option>
                <option value="MM/DD/YYYY">MM/DD/YYYY</option>
                <option value="DD Mon. YYYY" selected>DD Mon. YYYY</option>
                <option value="DD Month YYYY">DD Month YYYY</option>
                <option value="Mon. DD, YYYY">Mon. DD, YYYY</option>
                <option value="Month DD, YYYY">Month DD, YYYY</option>
                <option value="None">None</option>
              </select>
            </div>

            <!-- Outline Style -->
            <div>
              <label for="config-outlineItemStyle" class="block text-xs font-medium text-gray-600 mb-1">
                Outline Style
              </label>
              <select
                id="config-outlineItemStyle"
                class="w-full px-2 py-1 text-sm border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
              >
                <option value="plain" selected>Plain</option>
                <option value="withPage">With Page</option>
                <option value="withDate">With Date</option>
                <option value="withDateandPage">With Date and Page</option>
              </select>
            </div>
          </div>
        </div>

        <!-- Page Numbering -->
        <div class="pt-3 border-t border-gray-100">
          <h4 class="text-xs font-semibold text-gray-700 mb-2">Page Numbering</h4>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
            <!-- Footer Font -->
            <div>
              <label for="config-footerFont" class="block text-xs font-medium text-gray-600 mb-1">
                Footer Font
              </label>
              <select
                id="config-footerFont"
                class="w-full px-2 py-1 text-sm border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
              >
                <option value="sansSerif">Sans Serif</option>
                <option value="serif">Modern Serif</option>
                <option value="monospaced">Monospaced</option>
                <option value="traditional">Traditional Serif</option>
              </select>
            </div>

            <!-- Page Number Alignment -->
            <div>
              <label for="config-alignment" class="block text-xs font-medium text-gray-600 mb-1">
                Page Number Alignment
              </label>
              <select
                id="config-alignment"
                class="w-full px-2 py-1 text-sm border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
              >
                <option value="right">Right</option>
                <option value="left">Left</option>
                <option value="centre">Centre</option>
              </select>
            </div>

            <!-- Numbering Style -->
            <div>
              <label for="config-numberingStyle" class="block text-xs font-medium text-gray-600 mb-1">
                Numbering Style
              </label>
              <select
                id="config-numberingStyle"
                class="w-full px-2 py-1 text-sm border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
              >
                <option value="PageX">Page X</option>
                <option value="PageXofY">Page X of Y</option>
                <option value="X">X</option>
                <option value="XslashY">X/Y</option>
                <option value="XofY">X of Y</option>
                <option value="None">None</option>
              </select>
            </div>

            <!-- Footer Prefix -->
            <div>
              <label for="config-footerPrefix" class="block text-xs font-medium text-gray-600 mb-1">
                Footer Prefix
              </label>
              <input
                type="text"
                id="config-footerPrefix"
                class="w-full px-2 py-1 text-sm border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                placeholder="Optional prefix text"
              />
            </div>

            <!-- Printable Mode -->
            <div>
              <label for="config-printableBundle" class="block text-xs font-medium text-gray-600 mb-1">
                Printable Mode
              </label>
              <select
                id="config-printableBundle"
                class="w-full px-2 py-1 text-sm border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
              >
                <option value="true" selected>Add blank pages for printing</option>
                <option value="false">Don't add blank pages (Digital only bundle)</option>
              </select>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Submit button in Advanced Settings -->
    <div id="advanced-submit" class="bg-gradient-to-br from-slate-50 to-white rounded-xl shadow-sm border border-slate-200 hidden">
      <div class="p-3 flex justify-center">
        <button
          type="submit"
          class="inline-flex items-center px-8 py-3 bg-pink-500 hover:bg-pink-600 text-white text-base font-bold rounded-lg shadow-lg transition duration-150 ease-in-out focus:outline-none focus:ring-2 focus:ring-pink-500 focus:ring-offset-2 transform hover:scale-105"
        >
          <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Create Bundle
        </button>
      </div>
    </div>
  </form>

  <!-- Debug Output (hidden by default) -->
  <pre id="csv-output" class="hidden mt-8 bg-gray-900 text-gray-100 p-4 rounded-lg overflow-x-auto text-xs"></pre>
</div>

<style is:global>
  /* make the review table use a fixed layout so the colgroup widths are respected */
  #file-table table {
    table-layout: fixed;
    width: 100%;
  }

  /* ensure headers and cells wrap text rather than expanding the column */
  #file-table th,
  #file-table td {
    word-break: break-all;
    word-wrap: break-word;
    overflow-wrap: break-word;
    white-space: normal;
  }

  /* explicitly constrain the drag handle column (1st) */
  #file-table tbody td:nth-child(1) {
    max-width: 40px;
    width: 40px;
  }

  /* filename column (2nd) - 25% */
  #file-table tbody td:nth-child(2) {
    width: 25%;
    overflow: hidden;
  }

  /* title column (3rd) - 50% */
  #file-table tbody td:nth-child(3) {
    width: 50%;
  }

  /* Table cell styling for proper wrapping and prominence */
  #file-table-body td {
    vertical-align: top;
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  /* Title field styling - make it prominent */
  #file-table-body .title-cell {
    font-weight: 600;
    font-size: 1rem;
    color: #1e293b;
    line-height: 1.5;
    min-height: 2.5rem;
  }

  #file-table-body .title-cell:hover {
    background-color: #fce7f3;
    cursor: pointer;
  }

  /* Date field styling - make it prominent */
  #file-table-body .date-cell {
    font-weight: 500;
    font-size: 0.95rem;
    color: #475569;
    line-height: 1.5;
    white-space: normal;
  }

  #file-table-body .date-cell:hover {
    background-color: #fce7f3;
    cursor: pointer;
  }

  /* Filename styling - force wrapping */
  #file-table-body .filename-cell {
    font-size: 0.875rem;
    color: #64748b;
    line-height: 1.4;
    white-space: normal;
    word-break: break-all;
    overflow-wrap: anywhere;
    overflow: hidden;
  }

  /* Title cell - use textarea for multiline */
  #file-table-body .title-cell {
    width: 50%;
  }

  #file-table-body .title-cell textarea {
    min-width: 0;
    width: 100%;
    resize: vertical;
    min-height: 1.5rem;
    line-height: 1.4;
    field-sizing: content;
  }

  /* Date cell - constrain width */
  #file-table-body .date-cell {
    max-width: 180px;
    width: 180px;
  }

  #file-table-body .date-cell input {
    min-width: 0;
  }

  /* Pages styling */
  #file-table-body .pages-cell {
    font-size: 0.875rem;
    color: #64748b;
    text-align: center;
    max-width: 80px;
    width: 80px;
  }

  /* Row hover effect */
  #file-table-body tr:hover {
    background-color: #f8fafc;
  }

  /* Arrow buttons hidden by default (drag mode) */
  .move-up-btn, .move-down-btn {
    display: none;
  }

  /* Arrow mode: show arrows, hide drag handles, use card layout */
  #file-table.arrow-mode .move-up-btn,
  #file-table.arrow-mode .move-down-btn {
    display: inline-flex;
  }

  #file-table.arrow-mode .drag-handle {
    display: none;
  }

  #file-table.arrow-mode table { display: block; table-layout: auto; }
  #file-table.arrow-mode colgroup { display: none; }
  #file-table.arrow-mode thead { display: none; }
  #file-table.arrow-mode tbody { display: block; }

  #file-table.arrow-mode tbody tr {
    display: flex !important;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    padding: 0.5rem 0.75rem;
    background: white;
    width: 100%;
    box-sizing: border-box;
  }

  #file-table.arrow-mode tbody td {
    display: block;
    border: none;
    padding: 0.25rem 0;
    width: auto;
    max-width: none;
  }

  #file-table.arrow-mode tbody td:nth-child(2) { order: 1; flex: 1 1 auto; font-weight: 500; padding-right: 0.5rem; min-width: 0; }
  #file-table.arrow-mode tbody td:nth-child(6) { order: 2; flex: 0 0 auto; display: flex; gap: 0.5rem; align-items: center; }
  #file-table.arrow-mode tbody td:nth-child(3) { order: 3; flex: 1 1 100%; margin-top: 0.25rem; }
  #file-table.arrow-mode tbody td:nth-child(4) { order: 4; flex: 1 1 55%; margin-top: 0.25rem; }
  #file-table.arrow-mode tbody td:nth-child(5) { order: 5; flex: 1 1 40%; margin-top: 0.25rem; text-align: right; }

  /* Mobile card layout */
