<!-- Autosave welcome modal (shown once on first save) -->
<div id="autosave-welcome-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm">
  <div class="bg-white rounded-xl shadow-2xl border border-gray-200 p-5 max-w-sm w-full mx-4">
    <h3 class="text-sm font-semibold text-gray-800 mb-3">Welcome to BunTool's save feature</h3>
    <p class="text-sm text-gray-600 mb-5">This saves the state of your bundle locally on your machine, which can help to recover from errors. The saves are temporary though! If you want a long-term save, just press <strong>Create Bundle</strong> and save a full copy. Remember, you can always pick up from where you left off by clicking <strong>Edit an existing bundle</strong>.</p>
    <button id="autosave-welcome-ok" type="button" class="w-full px-4 py-2 text-sm font-medium text-white bg-green-600 hover:bg-green-700 rounded-lg transition">Got it</button>
  </div>
</div>

<!-- Autosave restore modal -->
<div id="autosave-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm">
  <div class="bg-white rounded-xl shadow-2xl border border-gray-200 p-4 max-w-xs w-full mx-4 flex flex-col max-h-[80vh]">
    <div class="flex items-center justify-between mb-3 shrink-0">
      <h3 class="text-sm font-semibold text-gray-800">Restore from autosave</h3>
      <button id="autosave-modal-close" type="button" class="text-gray-500 hover:text-gray-600 transition" aria-label="Close">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <p class="text-xs text-gray-500 mb-3 shrink-0">Restoring will replace your current documents and settings.</p>
    <div id="autosave-snapshot-list" class="space-y-2 overflow-y-auto"></div>
  </div>
</div>

<!-- Large bundle warning modal -->
<div id="large-bundle-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm">
  <div class="bg-white rounded-xl shadow-2xl border border-gray-200 p-6 max-w-sm w-full mx-4">
    <h3 class="text-base font-bold text-gray-800 mb-2">⚠️ Very large bundle</h3>
    <p class="text-sm text-gray-600 mb-5">It's very rare for single court bundles to be over 1000 pages or over 50MB in filesize. You may want to consider splitting the documents into two different files (e.g. "Bundle A" and "Bundle B"). If you proceed, BunTool may take longer than usual to process this file.</p>
    <div class="flex gap-3 justify-end">
      <button id="large-bundle-goback" type="button" class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition">
        Go back
      </button>
      <button id="large-bundle-proceed" type="button" class="px-4 py-2 text-sm font-medium text-white bg-pink-500 hover:bg-pink-600 rounded-lg transition">
        Proceed
      </button>
    </div>
  </div>
