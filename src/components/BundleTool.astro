---
// BundleTool component - PDF processing interface
---

<div id="bundle-tool-container" class="space-y-2">
  <form id="upload-form" class="space-y-2">
    <!-- Save & load controls -->
    <div id="edit-bundle-panel" class="flex flex-wrap items-start gap-2 px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg">
      <div class="flex flex-col gap-0.5">
        <button id="autosave-save-now-btn" type="button" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-blue-50 hover:bg-blue-100 border border-blue-200 text-blue-700 text-xs font-medium rounded-md transition">
          <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" />
          </svg>
          Save progress
        </button>
        <span class="text-[10px] text-gray-400 px-1">Save current work to browser</span>
      </div>
      <div class="flex flex-col gap-0.5">
        <button id="autosave-restore-btn" type="button" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-violet-50 hover:bg-violet-100 border border-violet-200 text-violet-700 text-xs font-medium rounded-md transition">
          <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Load saved progress
        </button>
        <span class="text-[10px] text-gray-400 px-1">Restore a previous session</span>
      </div>
      <div class="flex flex-col gap-0.5">
        <label for="bundle-input" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-teal-50 hover:bg-teal-100 border border-teal-200 text-teal-700 text-xs font-medium rounded-md transition cursor-pointer">
          <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
          </svg>
          Load from bundle PDF
        </label>
        <span class="text-[10px] text-gray-400 px-1">Reload from a previous bundle to edit</span>
      </div>
      <input type="file" id="bundle-input" accept="application/pdf" class="sr-only" />
    </div>

    <!-- Step 1: Basic Information -->
    <div id="step-1-info" class="bg-gradient-to-br from-slate-50 to-white rounded-xl shadow-sm border border-slate-200">
      <div class="px-3 py-2 bg-gradient-to-r from-slate-700 to-slate-800 rounded-t-xl">
        <h3 class="text-base font-bold text-white flex items-center">
          <span class="inline-flex items-center justify-center w-7 h-7 bg-pink-500 text-white rounded-full mr-2 text-sm font-bold shadow-lg">1</span>
          Basic Information
        </h3>
      </div>

      <div class="p-3 space-y-2">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <!-- Claim Number -->
          <div>
            <label for="config-claimNumber" class="block text-xs font-semibold text-gray-700 mb-1">
              Claim Number
            </label>
            <input
              type="text"
              id="config-claimNumber"
              class="w-full px-2 py-1 text-sm border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
              placeholder="e.g., 2026-ABC-123 or HP-2026-000001"
            />
          </div>

          <!-- Bundle Title -->
          <div>
            <label for="config-bundleTitle" class="block text-xs font-semibold text-gray-700 mb-1">
              Bundle Title
            </label>
            <input
              type="text"
              id="config-bundleTitle"
              placeholder="e.g., Bundle A: Statements of Case"
              class="w-full px-2 py-1 text-sm border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
            />
          </div>

          <!-- Project Name (Case Name) -->
          <div>
            <label for="config-projectName" class="block text-xs font-semibold text-gray-700 mb-1">
              Case Name
            </label>
            <input
              type="text"
              id="config-projectName"
              class="w-full px-2 py-1 text-sm border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
              placeholder="e.g., Smith v. Jones"
            />
          </div>

          <!-- Confidential Checkbox -->
          <div class="flex items-center h-full pt-4">
            <label class="flex items-center space-x-2 cursor-pointer">
              <input
                type="checkbox"
                id="config-confidential"
                class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500"
              />
              <span class="text-sm font-medium text-gray-700">Mark as <span class="text-red-500">Confidential</span>?</span>
            </label>
          </div>
        </div>

      </div>
    </div>

    <!-- Step 2: Select Documents -->
    <div id="file-drop-zone" class="bg-gradient-to-br from-slate-50 to-white rounded-xl shadow-sm border border-slate-200">
      <div class="px-3 py-2 bg-gradient-to-r from-slate-700 to-slate-800 rounded-t-xl">
        <h3 class="text-base font-bold text-white flex items-center">
          <span class="inline-flex items-center justify-center w-7 h-7 bg-pink-500 text-white rounded-full mr-2 text-sm font-bold shadow-lg">2</span>
          Select Documents
        </h3>
      </div>

      <div class="p-3">
        <p class="text-xs text-gray-500 mb-3">Start by adding PDF documents. You can divide them into sections now (or later — drag documents between sections at any time), but you don't have to. If you have a front-page coversheet, you can add that too.</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <!-- Add Documents -->
          <div class="flex flex-col items-center text-center gap-2">
            <label for="file-input" class="inline-flex items-center justify-center w-full px-4 py-2.5 bg-pink-500 hover:bg-pink-600 text-white text-sm font-semibold rounded-lg cursor-pointer transition shadow-sm">
              <svg class="w-4 h-4 mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
              Add Documents
            </label>
            <input type="file" id="file-input" multiple accept="application/pdf" class="sr-only" />
            <p id="file-input-hint" class="text-xs text-gray-500">Click to add PDFs, or drag and drop onto this area. <b>Files stay on your device — nothing is uploaded</b>.</p>
          </div>
          <!-- Add Section -->
          <div class="flex flex-col items-center text-center gap-2">
            <button type="button" class="add-section-btn inline-flex items-center justify-center w-full px-4 py-2.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold rounded-lg transition shadow-sm">
              <svg class="w-4 h-4 mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7" />
              </svg>
              Add Section
              <span class="ml-1.5 text-xs font-normal opacity-75">(optional)</span>
            </button>
            <p class="text-xs text-gray-500">Group documents into named sections (e.g. "Section A: Statements").</p>
          </div>
          <!-- Coversheet -->
          <div class="flex flex-col items-center text-center gap-2">
            <label for="coversheet-input" class="inline-flex items-center justify-center w-full px-4 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-600 text-sm font-medium rounded-lg cursor-pointer transition shadow-sm">
              <svg class="w-4 h-4 mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              <span id="coversheet-btn-text">Add Coversheet</span>
              <span class="ml-1.5 text-xs font-normal opacity-70">(optional)</span>
            </label>
            <input type="file" id="coversheet-input" accept="application/pdf" class="sr-only" />
            <div class="text-xs text-gray-500" id="coversheet-section">
              <span id="coversheet-filename" class="italic hidden"></span>
              <button id="coversheet-clear-btn" type="button" class="hidden text-red-400 hover:text-red-600 font-medium mr-1">Remove.</button>
              <span class="coversheet-hint">Add a pre-made first page before the index. BunTool uses only the first page if multi-page.</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Validation progress bar (shown while files are being read and validated) -->
    <div id="validation-progress" class="hidden rounded-xl border border-slate-200 bg-white px-4 py-3 shadow-sm">
      <div class="flex items-center justify-between mb-1.5">
        <span class="text-xs font-medium text-slate-600">Validating input files…</span>
        <span id="validation-progress-label" class="text-xs text-slate-400"></span>
      </div>
      <div class="w-full bg-slate-100 rounded-full h-2 overflow-hidden">
        <div id="validation-progress-bar" class="h-2 bg-pink-500 rounded-full transition-all duration-200" style="width:0%"></div>
      </div>
    </div>

    <!-- Step 3: Review Table -->
    <div id="file-table" class="bg-gradient-to-br from-slate-50 to-white rounded-xl shadow-sm border border-slate-200">
      <div class="px-3 py-2 bg-gradient-to-r from-slate-700 to-slate-800 rounded-t-xl flex items-center justify-between gap-3 flex-wrap">
        <div>
          <h3 class="text-base font-bold text-white flex items-center">
            <span class="inline-flex items-center justify-center w-7 h-7 bg-pink-500 text-white rounded-full mr-2 text-sm font-bold shadow-lg">3</span>
            Review Table
          </h3>
          <p class="mt-1 text-xs text-slate-200">Click titles/dates to edit</p>
        </div>
        <div class="flex items-center gap-3 shrink-0 flex-wrap justify-end">
          <button type="button" class="add-section-btn inline-flex items-center px-3 py-1.5 bg-blue-600 hover:bg-blue-700 text-white text-xs font-semibold rounded-lg transition shadow-sm">
            <svg class="w-3.5 h-3.5 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h7" />
            </svg>
            Add Section
          </button>
          <div class="flex items-center gap-2" title="Switch between drag-to-reorder and arrow buttons">
            <span class="text-xs text-slate-300">Sort with: &#x2195;</span>
            <label class="relative inline-flex items-center cursor-pointer">
              <input type="checkbox" id="reorder-toggle-btn" class="sr-only peer" checked>
              <div class="w-9 h-5 bg-slate-600 rounded-full peer peer-focus:ring-2 peer-focus:ring-blue-400 peer-checked:bg-blue-500 after:content-[''] after:absolute after:top-0.5 after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-full"></div>
            </label>
            <span class="text-xs text-slate-300">Drag</span>
          </div>
        </div>
      </div>

      <div id="file-table-empty" class="px-6 py-10 text-center text-gray-500">
        <svg class="w-8 h-8 mx-auto mb-2 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 13h6m-3-3v6m-9 1V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
        </svg>
        <p class="text-sm">Add documents above to get started</p>
      </div>

      <div class="overflow-x-auto hidden" id="file-table-content">
        <table class="min-w-full divide-y divide-gray-200">
          <colgroup>
            <col style="width: 40px;">
            <col style="width: 22%;">
            <col style="width: 45%;">
            <col style="width: 160px;">
            <col style="width: 70px;">
            <col style="width: 130px;">
          </colgroup>
          <thead class="bg-slate-100">
            <tr>
              <th class="px-2 py-2 text-left text-xs font-semibold text-slate-700 uppercase tracking-wider">
                <span class="sr-only">Drag</span>
              </th>
              <th class="px-3 py-2 text-left text-xs font-semibold text-slate-700 uppercase tracking-wider cursor-pointer select-none hover:bg-slate-200 transition" data-sort-col="filename" title="Click to sort within sections · Shift+click to sort all globally">Filename <span class="sort-indicator ml-1"></span></th>
              <th class="px-4 py-2 text-left text-xs font-semibold text-slate-700 uppercase tracking-wider cursor-pointer select-none hover:bg-slate-200 transition" data-sort-col="title" title="Click to sort within sections · Shift+click to sort all globally">Title <span class="sort-indicator ml-1"></span></th>
              <th class="px-4 py-2 text-left text-xs font-semibold text-slate-700 uppercase tracking-wider cursor-pointer select-none hover:bg-slate-200 transition" data-sort-col="date" title="Click to sort within sections · Shift+click to sort all globally">Date <span class="sort-indicator ml-1"></span></th>
              <th class="px-4 py-2 text-left text-xs font-semibold text-slate-700 uppercase tracking-wider cursor-pointer select-none hover:bg-slate-200 transition" data-sort-col="pages" title="Click to sort within sections · Shift+click to sort all globally">Pgs <span class="sort-indicator ml-1"></span></th>
              <th class="px-4 py-2 text-left text-xs font-semibold text-slate-700 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody id="tbody-section-0000" class="section-tbody bg-white divide-y divide-gray-200" data-section-id="0000">
            <!-- Default section — rows added by frontend.js -->
          </tbody>
        </table>
      </div>

      <!-- Table Controls -->
      <div class="px-4 py-2 border-t border-gray-200 flex justify-end items-center gap-2 flex-wrap">
        <button id="clear-all-rows-btn" type="button" class="inline-flex items-center px-3 py-1.5 bg-red-100 hover:bg-red-200 text-red-700 text-sm font-medium rounded-lg transition">
          <svg class="w-3.5 h-3.5 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
          Clear All
        </button>
      </div>
    </div>

    <!-- Section add-files popover (shown when clicking main add-files while sectioned) -->
    <div id="section-picker-popover" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/30">
      <div class="bg-white rounded-xl shadow-xl border border-gray-200 p-4 w-80 max-w-full mx-4">
        <h4 class="text-sm font-semibold text-gray-800 mb-3">Add files to which section?</h4>
        <div id="section-picker-list" class="flex flex-col gap-2 mb-3"></div>
        <button id="section-picker-cancel" type="button" class="w-full text-xs text-gray-500 hover:text-gray-700 transition py-1">Cancel</button>
      </div>
    </div>

    <!-- Step 4: Generate or Configure -->
    <div id="step-4-choice" class="bg-gradient-to-br from-slate-50 to-white rounded-xl shadow-sm border border-slate-200 no-docs">
      <div class="px-3 py-2 bg-gradient-to-r from-slate-700 to-slate-800 rounded-t-xl">
        <h3 class="text-base font-bold text-white flex items-center">
          <span class="inline-flex items-center justify-center w-7 h-7 bg-pink-500 text-white rounded-full mr-2 text-sm font-bold shadow-lg">4</span>
          Create Bundle
        </h3>
      </div>

      <div class="p-3 flex flex-col sm:flex-row gap-4 justify-center items-stretch">
        <div class="flex flex-col items-center gap-1.5">
          <button
            type="submit"
            id="create-bundle-btn"
            class="btn-needs-docs docs-inactive inline-flex items-center justify-center px-8 py-3 bg-pink-500 hover:bg-pink-600 text-white text-base font-bold rounded-lg shadow-lg transition duration-150 ease-in-out focus:outline-none focus:ring-2 focus:ring-pink-500 focus:ring-offset-2 transform hover:scale-105"
          >
            <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Create Bundle
          </button>
          <p class="text-xs text-gray-400 text-center max-w-[14rem]">Press to make a full pdf bundle with default settings</p>
        </div>

        <div class="flex flex-col items-center gap-1.5">
          <button
            id="preview-index-btn"
            type="button"
            class="btn-needs-docs docs-inactive inline-flex items-center justify-center px-5 py-3 bg-slate-100 hover:bg-slate-200 text-slate-600 text-sm font-medium rounded-lg transition duration-150 ease-in-out focus:outline-none focus:ring-2 focus:ring-slate-400 focus:ring-offset-2"
          >
            <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
            Preview Index
          </button>
          <p class="text-xs text-gray-400 text-center max-w-[14rem]">Just generate the index pages for preview</p>
        </div>

        <div class="flex flex-col items-center gap-1.5">
          <button
            id="show-advanced-btn"
            type="button"
            class="inline-flex items-center justify-center px-8 py-3 bg-slate-700 hover:bg-slate-800 text-white text-base font-semibold rounded-lg shadow-lg transition duration-150 ease-in-out focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-offset-2"
          >
            <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Advanced Settings
          </button>
          <p class="text-xs text-gray-400 text-center max-w-[14rem]">Choose fonts, sizes, and numbering. Includes Bates Numbering for Family Court.</p>
        </div>
      </div>
    </div>

    <!-- Advanced Settings (initially hidden) -->
    <div id="advanced-settings" class="bg-gradient-to-br from-slate-50 to-white rounded-xl shadow-sm border border-slate-200 hidden">
      <div class="px-3 py-2 bg-gradient-to-r from-slate-700 to-slate-800 rounded-t-xl flex flex-wrap items-center gap-2">
        <h3 class="text-base font-bold text-white flex items-center">
          <svg class="w-5 h-5 mr-2 text-pink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          Advanced Settings
        </h3>
        <div class="ml-auto flex gap-1 flex-wrap justify-end">
          <button id="save-defaults-btn" type="button" class="px-2 py-1 text-xs rounded border border-blue-400 text-blue-300 hover:bg-blue-700 hover:text-white transition">
            Save settings as defaults for future
          </button>
          <button id="erase-defaults-btn" type="button" class="px-2 py-1 text-xs rounded border border-red-500 text-red-300 hover:bg-red-700 hover:text-white transition">
            Erase saved defaults
          </button>
          <button id="reset-advanced-btn" type="button" class="px-2 py-1 text-xs rounded border border-slate-400 text-slate-300 hover:bg-slate-600 hover:text-white transition">
            Reset settings
          </button>
        </div>
      </div>

      <div class="p-3 space-y-3">

        <!-- Index Options -->
        <div class="bg-white rounded-lg border border-gray-200 p-3">
          <h4 class="text-m font-semibold text-gray-700 mb-2">Index Options</h4>

          <!-- Row 1: dropdowns -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-3">

            <!-- Index Font -->
            <div>
              <label for="config-fontFace" class="flex items-center text-xs font-semibold text-gray-700 mb-1">
                <svg class="w-3 h-3 mr-1 text-gray-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7h7m0 0V5m0 2v10m0 0h2m-2 0V5m4 14h4M17 5h-4m4 0v4m0-4v-.5" />
                </svg>
                Index Font
              </label>
              <select id="config-fontFace" class="w-full px-2 py-1 text-sm border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-transparent transition">
                <optgroup label="Standard fonts">
                  <option value="times">Times style (Charis)</option>
                  <option value="helvetica">Arial style (Liberation Sans)</option>
                  <option value="traditional">Georgia style (Garamond)</option>
                </optgroup>
                <optgroup label="Other fonts">
                  <option value="sansSerif">Sans Serif (Plus Jakarta)</option>
