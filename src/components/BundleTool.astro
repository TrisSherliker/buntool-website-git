---
// BundleTool component - PDF processing interface
---

<div id="bundle-tool-container" class="space-y-2">
  <form id="upload-form" class="space-y-2">
    <!-- Edit existing bundle -->
    <div id="edit-bundle-panel" class="bg-white rounded-xl shadow-sm border border-blue-200 p-3 flex items-center gap-3">
      <p class="text-xs text-gray-400 flex-1">If you want to edit an existing bundle, upload here. Otherwise, just follow the steps below.</p>
      <label for="bundle-input" class="inline-flex items-center px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold rounded-lg cursor-pointer transition shadow-sm whitespace-nowrap shrink-0">
        <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
        </svg>
        Edit an existing bundle
      </label>
      <input type="file" id="bundle-input" accept="application/pdf" class="sr-only" />
    </div>

    <!-- Step 1: Basic Information -->
    <div id="step-1-info" class="bg-gradient-to-br from-slate-50 to-white rounded-xl shadow-sm border border-slate-200">
      <div class="px-3 py-2 bg-gradient-to-r from-slate-700 to-slate-800 rounded-t-xl">
        <h3 class="text-base font-bold text-white flex items-center">
          <span class="inline-flex items-center justify-center w-7 h-7 bg-pink-500 text-white rounded-full mr-2 text-sm font-bold shadow-lg">1</span>
          Basic Information
        </h3>
      </div>

      <div class="p-3 space-y-2">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <!-- Claim Number -->
          <div>
            <label for="config-claimNumber" class="block text-xs font-medium text-gray-600 mb-1">
              Claim Number
            </label>
            <input
              type="text"
              id="config-claimNumber"
              class="w-full px-2 py-1 text-sm border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
              placeholder="e.g., 2026-ABC-123 or HP-2026-000001"
            />
          </div>

          <!-- Bundle Title -->
          <div>
            <label for="config-bundleTitle" class="block text-xs font-medium text-gray-600 mb-1">
              Bundle Title
            </label>
            <input
              type="text"
              id="config-bundleTitle"
              placeholder="e.g., Bundle A: Statements of Case"
              class="w-full px-2 py-1 text-sm border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
            />
          </div>

          <!-- Project Name (Case Name) -->
          <div>
            <label for="config-projectName" class="block text-xs font-medium text-gray-600 mb-1">
              Case Name
            </label>
            <input
              type="text"
              id="config-projectName"
              class="w-full px-2 py-1 text-sm border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
              placeholder="e.g., Smith v. Jones"
            />
          </div>

          <!-- Confidential Checkbox -->
          <div class="flex items-center h-full pt-4">
            <label class="flex items-center space-x-2 cursor-pointer">
              <input
                type="checkbox"
                id="config-confidential"
                class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500"
              />
              <span class="text-sm font-medium text-gray-700">Mark as <span class="text-red-500">Confidential</span>?</span>
            </label>
          </div>
        </div>

      </div>
    </div>

    <!-- Step 2: Select Documents -->
    <div id="file-drop-zone" class="bg-gradient-to-br from-slate-50 to-white rounded-xl shadow-sm border border-slate-200">
      <div class="px-3 py-2 bg-gradient-to-r from-slate-700 to-slate-800 rounded-t-xl">
        <h3 class="text-base font-bold text-white flex items-center">
          <span class="inline-flex items-center justify-center w-7 h-7 bg-pink-500 text-white rounded-full mr-2 text-sm font-bold shadow-lg">2</span>
          Select Documents
        </h3>
      </div>

      <div class="p-3 flex items-center gap-3">
        <p id="file-input-hint" class="text-xs text-gray-400 flex-1">Add files by clicking the button, or dragging and dropping. <b>Files stay on your device — nothing is uploaded</b>.</p>
        <label for="file-input" class="inline-flex items-center px-5 py-2.5 bg-pink-500 hover:bg-pink-600 text-white text-sm font-semibold rounded-lg cursor-pointer transition shadow-sm whitespace-nowrap shrink-0">
          <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          Click to add documents
        </label>
        <input type="file" id="file-input" multiple accept="application/pdf" class="sr-only" />
      </div>
    </div>

    <!-- Step 3: Review Table -->
    <div id="file-table" class="bg-gradient-to-br from-slate-50 to-white rounded-xl shadow-sm border border-slate-200">
      <div class="px-3 py-2 bg-gradient-to-r from-slate-700 to-slate-800 rounded-t-xl flex items-center justify-between gap-3 flex-wrap">
        <div>
          <h3 class="text-base font-bold text-white flex items-center">
            <span class="inline-flex items-center justify-center w-7 h-7 bg-pink-500 text-white rounded-full mr-2 text-sm font-bold shadow-lg">3</span>
            Review Table
          </h3>
          <p class="mt-1 text-xs text-slate-200">Click titles/dates to edit</p>
        </div>
        <div class="flex items-center gap-2 shrink-0" title="Switch between drag-to-reorder and arrow buttons">
          <span class="text-xs text-slate-300">Sort with: &#x2195;</span>
          <label class="relative inline-flex items-center cursor-pointer">
            <input type="checkbox" id="reorder-toggle-btn" class="sr-only peer" checked>
            <div class="w-9 h-5 bg-slate-600 rounded-full peer peer-focus:ring-2 peer-focus:ring-blue-400 peer-checked:bg-blue-500 after:content-[''] after:absolute after:top-0.5 after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-full"></div>
          </label>
          <span class="text-xs text-slate-300">Drag</span>
        </div>
      </div>

      <div id="file-table-empty" class="px-6 py-10 text-center text-gray-400">
        <svg class="w-8 h-8 mx-auto mb-2 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 13h6m-3-3v6m-9 1V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
        </svg>
        <p class="text-sm">Add documents above to get started</p>
      </div>

      <div class="overflow-x-auto hidden" id="file-table-content">
        <table class="min-w-full divide-y divide-gray-200">
          <colgroup>
            <col style="width: 40px;">
            <col style="width: 25%;">
            <col style="width: 50%;">
            <col style="width: 180px;">
            <col style="width: 60px;">
            <col style="width: 80px;">
          </colgroup>
          <thead class="bg-slate-100">
            <tr>
              <th class="px-2 py-2 text-left text-xs font-semibold text-slate-700 uppercase tracking-wider">
                <span class="sr-only">Drag</span>
              </th>
              <th class="px-3 py-2 text-left text-xs font-semibold text-slate-700 uppercase tracking-wider cursor-pointer select-none hover:bg-slate-200 transition" data-sort-col="filename">Filename <span class="sort-indicator ml-1"></span></th>
              <th class="px-4 py-2 text-left text-xs font-semibold text-slate-700 uppercase tracking-wider cursor-pointer select-none hover:bg-slate-200 transition" data-sort-col="title">Title <span class="sort-indicator ml-1"></span></th>
              <th class="px-4 py-2 text-left text-xs font-semibold text-slate-700 uppercase tracking-wider cursor-pointer select-none hover:bg-slate-200 transition" data-sort-col="date">Date <span class="sort-indicator ml-1"></span></th>
              <th class="px-4 py-2 text-left text-xs font-semibold text-slate-700 uppercase tracking-wider cursor-pointer select-none hover:bg-slate-200 transition" data-sort-col="pages">Pages <span class="sort-indicator ml-1"></span></th>
              <th class="px-4 py-2 text-left text-xs font-semibold text-slate-700 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody id="file-table-body" class="bg-white divide-y divide-gray-200">
            <!-- Rows will be added here by frontend.js -->
          </tbody>
        </table>
      </div>

      <!-- Table Controls -->
      <div class="px-4 py-2 border-t border-gray-200 flex justify-between items-center gap-2 flex-wrap">
        <button id="add-section-break-btn" type="button" class="inline-flex items-center px-3 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-lg transition">
          <svg class="w-3.5 h-3.5 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          Add Section Break
        </button>
        <button id="clear-all-rows-btn" type="button" class="inline-flex items-center px-3 py-1.5 bg-red-100 hover:bg-red-200 text-red-700 text-sm font-medium rounded-lg transition">
          <svg class="w-3.5 h-3.5 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
          Clear All
        </button>
      </div>
    </div>

    <!-- Step 4: Generate or Configure -->
    <div id="step-4-choice" class="bg-gradient-to-br from-slate-50 to-white rounded-xl shadow-sm border border-slate-200 no-docs">
      <div class="px-3 py-2 bg-gradient-to-r from-slate-700 to-slate-800 rounded-t-xl">
        <h3 class="text-base font-bold text-white flex items-center">
          <span class="inline-flex items-center justify-center w-7 h-7 bg-pink-500 text-white rounded-full mr-2 text-sm font-bold shadow-lg">4</span>
          Create Bundle
        </h3>
      </div>

      <div class="p-3 flex flex-col sm:flex-row gap-2 justify-center">
        <button
          type="submit"
          id="create-bundle-btn"
          class="btn-needs-docs docs-inactive inline-flex items-center justify-center px-8 py-3 bg-pink-500 hover:bg-pink-600 text-white text-base font-bold rounded-lg shadow-lg transition duration-150 ease-in-out focus:outline-none focus:ring-2 focus:ring-pink-500 focus:ring-offset-2 transform hover:scale-105"
        >
          <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Create Bundle
        </button>

        <button
          id="preview-index-btn"
          type="button"
          class="btn-needs-docs docs-inactive inline-flex items-center justify-center px-5 py-3 bg-slate-100 hover:bg-slate-200 text-slate-600 text-sm font-medium rounded-lg transition duration-150 ease-in-out focus:outline-none focus:ring-2 focus:ring-slate-400 focus:ring-offset-2"
        >
          <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
          </svg>
          Preview Index
        </button>

        <button
          id="show-advanced-btn"
          type="button"
          class="inline-flex items-center justify-center px-8 py-3 bg-slate-700 hover:bg-slate-800 text-white text-base font-semibold rounded-lg shadow-lg transition duration-150 ease-in-out focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-offset-2"
        >
          <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          Advanced Settings
        </button>
      </div>
    </div>

    <!-- Advanced Settings (initially hidden) -->
    <div id="advanced-settings" class="bg-gradient-to-br from-slate-50 to-white rounded-xl shadow-sm border border-slate-200 hidden">
      <div class="px-3 py-2 bg-gradient-to-r from-slate-700 to-slate-800 rounded-t-xl flex flex-wrap items-center gap-2">
        <h3 class="text-base font-bold text-white flex items-center">
          <svg class="w-5 h-5 mr-2 text-pink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          Advanced Settings
        </h3>
        <div class="ml-auto flex gap-1 flex-wrap justify-end">
          <button id="save-defaults-btn" type="button" class="px-2 py-1 text-xs rounded border border-blue-400 text-blue-300 hover:bg-blue-700 hover:text-white transition">
            Save settings as defaults for future
          </button>
          <button id="erase-defaults-btn" type="button" class="px-2 py-1 text-xs rounded border border-red-500 text-red-300 hover:bg-red-700 hover:text-white transition">
            Erase saved defaults
          </button>
          <button id="reset-advanced-btn" type="button" class="px-2 py-1 text-xs rounded border border-slate-400 text-slate-300 hover:bg-slate-600 hover:text-white transition">
            Reset settings
          </button>
        </div>
      </div>

      <div class="p-3 space-y-3">

        <!-- Index Options -->
        <div>
          <h4 class="text-m font-semibold text-gray-700 mb-2">Index Options</h4>

          <!-- Row 1: dropdowns -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-3">

            <!-- Index Font -->
            <div>
              <label for="config-fontFace" class="flex items-center text-xs font-medium text-gray-600 mb-1">
                <svg class="w-3 h-3 mr-1 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7h7m0 0V5m0 2v10m0 0h2m-2 0V5m4 14h4M17 5h-4m4 0v4m0-4v-.5" />
                </svg>
                Index Font
              </label>
              <select id="config-fontFace" class="w-full px-2 py-1 text-sm border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-transparent transition">
                <option value="sansSerif">Sans Serif</option>
                <option value="serif">Modern Serif</option>
                <option value="monospaced">Monospaced</option>
                <option value="traditional">Traditional Serif</option>
              </select>
              <p class="text-xs text-gray-400 mt-1">Typeface used for the table of contents.</p>
            </div>

            <!-- Date Format -->
            <div>
              <label for="config-dateStyle" class="flex items-center text-xs font-medium text-gray-600 mb-1">
                <svg class="w-3 h-3 mr-1 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                Date Format
              </label>
              <select id="config-dateStyle" class="w-full px-2 py-1 text-sm border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-transparent transition">
                <option value="YYYY-MM-DD">YYYY-MM-DD</option>
                <option value="DD-MM-YYYY">DD-MM-YYYY</option>
                <option value="MM/DD/YYYY">MM/DD/YYYY</option>
                <option value="DD Mon. YYYY" selected>DD Mon. YYYY</option>
                <option value="DD Month YYYY">DD Month YYYY</option>
                <option value="Mon. DD, YYYY">Mon. DD, YYYY</option>
                <option value="Month DD, YYYY">Month DD, YYYY</option>
                <option value="None">None</option>
              </select>
              <p class="text-xs text-gray-400 mt-1">How document dates appear in the index. 'None' hides the date column.</p>
            </div>

            <!-- Outline Style -->
            <div>
              <label for="config-outlineItemStyle" class="flex items-center text-xs font-medium text-gray-600 mb-1">
                <svg class="w-3 h-3 mr-1 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
                </svg>
                Outline Style
              </label>
              <select id="config-outlineItemStyle" class="w-full px-2 py-1 text-sm border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-transparent transition">
                <option value="plain" selected>Plain</option>
                <option value="withPage">With Page</option>
                <option value="withDate">With Date</option>
                <option value="withDateandPage">With Date and Page</option>
              </select>
              <p class="text-xs text-gray-400 mt-1">How entries appear in the PDF bookmarks panel.</p>
            </div>
          </div>

          <!-- Row 2: button groups + toggle -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mt-3">

            <!-- Heading Font Size -->
            <div>
              <label class="flex items-center text-xs font-medium text-gray-600 mb-1">
                <svg class="w-3 h-3 mr-1 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16" />
                </svg>
                Heading Font Size
              </label>
              <div class="flex rounded border border-gray-300 overflow-hidden">
                <button type="button" data-group="headingFontSize" data-value="small" class="btn-group flex-1 px-3 py-1 text-xs border-r border-gray-300 bg-white text-gray-700 hover:bg-blue-50 transition">Small</button>
                <button type="button" data-group="headingFontSize" data-value="medium" class="btn-group flex-1 px-3 py-1 text-xs border-r border-gray-300 bg-blue-500 text-white transition">Med</button>
                <button type="button" data-group="headingFontSize" data-value="large" class="btn-group flex-1 px-3 py-1 text-xs bg-white text-gray-700 hover:bg-blue-50 transition">Large</button>
              </div>
              <input type="hidden" id="config-headingFontSize" value="medium">
              <p class="text-xs text-gray-400 mt-1">Size of the bundle title and project name.</p>
            </div>

            <!-- Index Font Size -->
            <div>
              <label class="flex items-center text-xs font-medium text-gray-600 mb-1">
                <svg class="w-3 h-3 mr-1 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
                </svg>
                Index Font Size
              </label>
              <div class="flex rounded border border-gray-300 overflow-hidden">
                <button type="button" data-group="indexFontSize" data-value="small" class="btn-group flex-1 px-3 py-1 text-xs border-r border-gray-300 bg-white text-gray-700 hover:bg-blue-50 transition">Small</button>
                <button type="button" data-group="indexFontSize" data-value="medium" class="btn-group flex-1 px-3 py-1 text-xs border-r border-gray-300 bg-blue-500 text-white transition">Med</button>
                <button type="button" data-group="indexFontSize" data-value="large" class="btn-group flex-1 px-3 py-1 text-xs bg-white text-gray-700 hover:bg-blue-50 transition">Large</button>
              </div>
              <input type="hidden" id="config-indexFontSize" value="medium">
              <p class="text-xs text-gray-400 mt-1">Size of text in the index table.</p>
            </div>

            <!-- Table Borders toggle -->
            <div>
              <p class="flex items-center text-xs font-medium text-gray-600 mb-1">
                <svg class="w-3 h-3 mr-1 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M3 14h18M10 3v18M14 3v18M5 3h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2z" />
                </svg>
                Table Borders
              </p>
              <label class="relative inline-flex items-center cursor-pointer gap-2 mt-1">
                <input type="checkbox" id="config-showTableBorders" class="sr-only peer" checked>
                <div class="w-9 h-5 bg-gray-200 rounded-full peer peer-focus:ring-2 peer-focus:ring-blue-500 peer-checked:bg-blue-500 after:content-[''] after:absolute after:top-0.5 after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-full"></div>
                <span class="text-xs text-gray-500 peer-checked:text-blue-600 transition">On</span>
              </label>
              <p class="text-xs text-gray-400 mt-1">Show or hide grid lines in the index table.</p>
            </div>
          </div>
        </div>

        <!-- Page Numbering -->
        <div class="pt-3 border-t border-gray-100">
