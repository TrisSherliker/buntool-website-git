<link href="https://unpkg.com/tabulator-tables@6.3.0/dist/css/tabulator.min.css" rel="stylesheet">

<script>
  // Progressive disclosure: Show Step 4 when table has files
  const fileTableBody = document.getElementById('file-table-body');
  const step4Choice = document.getElementById('step-4-choice');

  // Observer to watch for changes in the table
  const observer = new MutationObserver(() => {
    const hasFiles = fileTableBody.querySelectorAll('tr').length > 0;
    if (hasFiles) {
      step4Choice?.classList.remove('hidden');
    } else {
      step4Choice?.classList.add('hidden');
    }
  });

  if (fileTableBody) {
    observer.observe(fileTableBody, { childList: true });
  }

  // Advanced Settings toggle
  const showAdvancedBtn = document.getElementById('show-advanced-btn');
  const advancedSettings = document.getElementById('advanced-settings');
  const advancedSubmit = document.getElementById('advanced-submit');

  showAdvancedBtn?.addEventListener('click', () => {
    advancedSettings?.classList.remove('hidden');
    advancedSubmit?.classList.remove('hidden');
    step4Choice?.classList.add('hidden');

    // Scroll to advanced settings
    advancedSettings?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>

<script type="module" src="/js/frontend.js"></script>
