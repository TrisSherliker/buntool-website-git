---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BundleTool from '../components/BundleTool.astro';
---

<Layout title="BunTool - Create Your Bundle" description="Upload PDFs and create a court bundle. All processing happens on your device for complete privacy.">
	<Header currentPath="/app" />

	<main class="min-h-screen bg-gray-50">
		<!-- Privacy Banner -->
		<div class="bg-blue-50 border-b border-blue-100">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
				<div class="flex items-center justify-center space-x-2 text-sm">
					<svg class="h-4 w-4 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
					</svg>
					<span class="text-blue-900">
						<strong>100% Private:</strong> All processing happens in your browser. Your files never leave your device.
					</span>
				</div>
			</div>
		</div>

		<!-- Main Content -->
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
			<!-- Page Header -->
			<div class="mb-8">
				<h2 class="text-2xl font-bold text-gray-900 mb-2">Create Your Court Bundle</h2>
				<p class="text-gray-600">Configure your bundle settings, upload PDFs, and generate a professional court-ready document.</p>
			</div>

			<!-- App Interface -->
			<BundleTool />
		</div>
	</main>

	<Footer />
</Layout>
